# Exemple de variables d'environnement locales
# Copie ce fichier en .env (il est ignoré par git) et remplace les valeurs.

# Hugging Face (recommandé pour éviter les rate limits)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optionnel) Déplacer les caches sur D: si C: est limité
HF_HOME=D:\hf-cache
HF_HUB_CACHE=D:\hf-cache\hub
TRANSFORMERS_CACHE=D:\hf-cache\transformers
HF_DATASETS_CACHE=D:\hf-cache\datasets

# (Optionnel) Réduire la fragmentation mémoire CUDA sur petites VRAM
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:64
